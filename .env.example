# Core
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public"
AUTH_SECRET="replace_with_long_random_secret"

# Public/absolute URLs (Railway: set both to your service/custom domain)
AUTH_URL="https://your-app.up.railway.app"
NEXT_PUBLIC_SITE_URL="https://your-app.up.railway.app"
NEXTAUTH_URL="https://your-app.up.railway.app"

# Optional: first admin credentials for seed
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-strong"

# Optional: run prisma db push + seed during app startup (recommended OFF on Railway)
# RUN_DB_SETUP_ON_START="false"

# Optional: persistent uploads path (Railway Volume)
# UPLOAD_DIR="/app/public/uploads"
