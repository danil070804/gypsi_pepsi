{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildEnvironment": "v3"
  },
  "deploy": {
    "runtime": "v3",
    "numReplicas": 1,
    "sleepApplication": false,
    "useLegacyStacker": false,
    "ingressEnabled": false,
    "multiRegionConfig": {
      "us-west2": {
        "numReplicas": 1
      }
    },
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
